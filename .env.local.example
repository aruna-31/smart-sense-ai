# ─── Frontend Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in values. NEVER commit .env.local

# URL of the deployed FastAPI backend (no trailing slash)
# In production (Render), set this as an Environment Variable in the frontend service.
VITE_BACKEND_URL=https://smart-sense-ai-backend.onrender.com

# Optional: Gemini key (only needed if frontend calls Gemini directly, not via backend)
GEMINI_API_KEY=
