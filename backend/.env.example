# Copy to .env and fill values
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# Optional: if using a custom Gemini HTTP endpoint
GEMINI_API_URL=https://api.example.com/v1/generate
# Stripe billing (optional) - set when you want to accept payments
STRIPE_API_KEY=
STRIPE_PRICE_ID=
STRIPE_SUCCESS_URL=http://localhost:3000/
STRIPE_CANCEL_URL=http://localhost:3000/
STRIPE_WEBHOOK_SECRET=
# PhonePe payment (dev): place your PhonePe QR image at public/phonepe-qr.png to enable QR-based pay flow
# For development testing of manual payments ("I've Paid (Dev)"), set ALLOW_DEV_PAYMENTS=true in backend .env (DO NOT enable in production)
ALLOW_DEV_PAYMENTS=true
PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
